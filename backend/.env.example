# Copiar a .env y ajustar segun el entorno.
# En desarrollo, la base corre en docker-compose.yml (usuario/clave: postgres/postgres).

# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/almacenes_db?schema=public"

# Servidor
PORT=3000
API_PREFIX=api/v1
NODE_ENV=development

# JWT (usar secretos largos y aleatorios en produccion, ej: openssl rand -hex 32)
JWT_ACCESS_SECRET="cambiar-en-produccion"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="cambiar-en-produccion-distinto-al-anterior"
JWT_REFRESH_EXPIRES_IN="7d"

# Usuario super_admin inicial (bootstrap, creado por el seed si no existe ninguno)
SEED_ADMIN_USER="admin"
SEED_ADMIN_PASSWORD="cambiar-en-produccion"
SEED_ADMIN_NOMBRE="Administrador del Sistema"
