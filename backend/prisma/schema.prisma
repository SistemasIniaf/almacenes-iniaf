// Sistema de Almacenes (multi-almacen) — Institucion Publica
// Paso 2 del roadmap: catalogo y usuarios. NO incluye aun stock/ingresos/egresos/kardex.
// Docs: ver CLAUDE.md en la raiz del repo.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Rol {
  super_admin
  admin
  solicitador
  aprobador
  responsable_almacen
  observador_almacen
}

/// Estado del Ingreso. BORRADOR (reserva, no toca stock) -> CONFIRMADO (crea
/// lotes + kardex, estampa numero) -> ANULADO (revierte). Ver decisiones-ingresos.md.
enum EstadoIngreso {
  BORRADOR
  CONFIRMADO
  ANULADO
}

/// Tipo de movimiento del Kardex. Por ahora ENTRADA (ingreso confirmado) y
/// REVERSION (anulacion de ingreso). SALIDA llega con Egresos.
enum TipoMovimiento {
  ENTRADA
  SALIDA
  REVERSION
}

// ---------------------------------------------------------------------------
// Entidades
// ---------------------------------------------------------------------------

/// Area administrativa (ej. Unidad de Planificacion).
/// Jerarquica: cada unidad puede tener un padre (sin limite de niveles).
/// Si padreId es null, es una Oficina Inicial (raiz).
model Unidad {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  sigla  String  @unique
  activo Boolean @default(true)

  /// Grupo de la unidad (MOF, OTROS...) en MAYUSCULAS. Lo elige la unidad RAIZ;
  /// los hijos heredan el del padre (todo el subarbol comparte grupo). Sirve para
  /// mostrar el catalogo en tablas por grupo y para agrupar el selector del almacen.
  grupo String? @map("grupo")

  // Jerarquia auto-referenciada (similar a Partida pero sin limite de niveles).
  padreId Int?     @map("padre_id")
  padre   Unidad?  @relation("UnidadJerarquia", fields: [padreId], references: [id])
  hijos   Unidad[] @relation("UnidadJerarquia")

  usuarios            Usuario[]
  almacenes           AlmacenUnidad[]
  ingresosSolicitados Ingreso[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([padreId])
  @@index([grupo])
  @@map("unidades")
}

/// Almacen fisico. La institucion tiene 9+.
model Almacen {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  activo Boolean @default(true)

  usuarios     Usuario[]
  observadores UsuarioAlmacenObservado[]
  unidades     AlmacenUnidad[]
  ingresos     Ingreso[]
  movimientos  MovimientoKardex[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("almacenes")
}

/// Tabla puente (muchos-a-muchos) Almacen <-> Unidad, 2026-07-23.
/// Las unidades son un CATALOGO COMPARTIDO y cada almacen SELECCIONA cuales
/// muestra en el selector de "unidad solicitante" del Ingreso. Asi los rubros
/// departamentales (Adm. y Finanzas, Departamental...) se crean una sola vez y
/// se reusan en cada almacen departamental (el Nacional apunta a su organigrama).
model AlmacenUnidad {
  almacenId Int @map("almacen_id")
  unidadId  Int @map("unidad_id")

  almacen Almacen @relation(fields: [almacenId], references: [id], onDelete: Cascade)
  unidad  Unidad  @relation(fields: [unidadId], references: [id], onDelete: Cascade)

  @@id([almacenId, unidadId])
  @@index([unidadId])
  @@map("almacen_unidad")
}

/// Usuario del sistema. Se crea solo desde el modulo usuarios (no hay registro publico).
/// unidadId y almacenId son independientes entre si y opcionales segun el rol:
///   - super_admin / admin: sin unidad ni almacen, y sin cargo obligatorio.
///   - solicitador: unidad + almacen requeridos.
///   - aprobador: unidad + almacen requeridos (unico activo por unidad).
///   - responsable_almacen: unidad + almacen requeridos (unico activo por almacen).
///   - observador_almacen: sin almacen fijo (usa UsuarioAlmacenObservado).
/// `cargo` es opcional en la BD porque los dos roles administrativos no lo
/// llevan; para el resto lo exige el service.
/// `nombre` y `cargo` se guardan SIEMPRE en MAYUSCULAS (normalizado en el service).
model Usuario {
  id       Int     @id @default(autoincrement())
  nombre   String
  cargo    String?
  usuario  String  @unique
  password String
  rol      Rol
  activo   Boolean @default(true)

  unidadId  Int?     @map("unidad_id")
  unidad    Unidad?  @relation(fields: [unidadId], references: [id])
  almacenId Int?     @map("almacen_id")
  almacen   Almacen? @relation(fields: [almacenId], references: [id])

  almacenesObservados UsuarioAlmacenObservado[]

  // Relaciones con Ingreso (multiples, por eso llevan nombre).
  ingresosRegistrados  Ingreso[] @relation("IngresoRegistradoPor")
  ingresosConformidad  Ingreso[] @relation("IngresoResponsableConformidad")
  ingresosAnulados     Ingreso[] @relation("IngresoAnuladoPor")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([unidadId])
  @@index([almacenId])
  @@map("usuarios")
}

/// Tabla intermedia (muchos-a-muchos) para los almacenes que un observador_almacen puede ver.
model UsuarioAlmacenObservado {
  id        Int @id @default(autoincrement())
  usuarioId Int @map("usuario_id")
  almacenId Int @map("almacen_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  almacen Almacen @relation(fields: [almacenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([usuarioId, almacenId])
  @@index([almacenId])
  @@map("usuario_almacen_observado")
}

/// Clasificador por Objeto del Gasto (jerarquico, hasta 5 niveles).
/// NO se crea a mano: se importa/semilla desde el documento oficial (ver prisma/seed.ts).
/// nivel = 5 - (cantidad de ceros finales del codigo de 5 digitos).
/// seleccionable = true SOLO en nodos hoja (los unicos asignables a un Item).
model Partida {
  id                Int     @id @default(autoincrement())
  codigo            String  @unique
  denominacion      String
  nivel             Int
  seleccionable     Boolean @default(false)
  activo            Boolean @default(true)
  ultimoCorrelativo Int     @default(0) @map("ultimo_correlativo")

  padreId Int?      @map("padre_id")
  padre   Partida?  @relation("PartidaJerarquia", fields: [padreId], references: [id])
  hijos   Partida[] @relation("PartidaJerarquia")

  items Item[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([padreId])
  @@map("partidas")
}

/// Proveedor de la institucion. Sera referenciado por Ingreso (fase posterior),
/// por eso nunca se borra: baja logica via `activo`.
/// nit es opcional (hay proveedores sin NIT) pero unico cuando existe:
/// Postgres admite multiples NULL en un indice unico.
model Proveedor {
  id        Int     @id @default(autoincrement())
  nombre    String
  nit       String? @unique
  telefono  String?
  /// Nombre de la persona de contacto (ej. "Juan Perez, ejecutivo de ventas").
  contacto  String?
  direccion String?
  activo    Boolean @default(true)

  ingresos Ingreso[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("proveedores")
}

/// Fuente de financiamiento del Ingreso (Recursos Especificos, Banco Mundial,
/// COSUDE, DANIDA, programas TGN...). Va en la CABECERA del Ingreso: una sola
/// fuente por ingreso. El stock se separa por fuente porque cada financiador
/// exige rendir cuentas de SU plata (ver docs/decisiones-ingresos.md, punto 1).
/// Baja logica siempre: quedara referenciada por lotes historicos y borrarla
/// romperia el kardex, igual que pasa con Proveedor.
model FuenteFinanciamiento {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  /// Opcional, por si el area financiera maneja un codigo propio.
  codigo String?
  activo Boolean @default(true)

  ingresos Ingreso[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fuentes_financiamiento")
}

/// Item real de almacen (catalogo compartido entre todos los almacenes).
/// codigo autogenerado al crear: {partida.codigo}-{correlativo padStart(6)} (ej. "39700-000001").
/// El stock NO vive aqui (ira en StockAlmacen, fase posterior).
model Item {
  id           Int     @id @default(autoincrement())
  codigo       String  @unique
  descripcion  String
  unidadMedida String  @map("unidad_medida")
  // Ruta publica relativa de la imagen referencial (ej. "/uploads/items/12-a3f9.webp").
  // Null = sin imagen. El binario vive en el filesystem, no en la DB.
  imagenUrl    String? @map("imagen_url")
  activo       Boolean @default(true)

  partidaId Int     @map("partida_id")
  partida   Partida @relation(fields: [partidaId], references: [id])

  ingresoDetalles IngresoDetalle[]
  movimientos     MovimientoKardex[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([partidaId])
  @@map("items")
}

/// Ingreso de material a un almacen (cabecera). El detalle son los LOTES.
/// Lo registra el responsable_almacen de ese almacen, SIN aprobacion.
/// Flujo: BORRADOR (reserva, no toca stock) -> CONFIRMADO (estampa numero,
/// crea lotes + kardex) -> ANULADO (revierte). El numero es correlativo POR
/// ALMACEN + GESTION, se asigna al confirmar (se imprime "001/2026").
/// Los respaldos son nullable: en BORRADOR no se exigen; el service los pide al
/// confirmar. Ver docs/decisiones-ingresos.md.
model Ingreso {
  id     Int           @id @default(autoincrement())
  estado EstadoIngreso @default(BORRADOR)

  numero  Int? // null hasta confirmar
  gestion Int? @map("gestion") // anio; null hasta confirmar

  almacenId Int     @map("almacen_id")
  almacen   Almacen @relation(fields: [almacenId], references: [id])

  // Respaldos del documento (se exigen al confirmar, no en borrador).
  fechaRemision           DateTime? @map("fecha_remision")
  notaRemision            String?   @map("nota_remision")
  procesoC31              String?   @map("proceso_c31")
  certificacion           String?
  informeConformidad      String?   @map("informe_conformidad")
  fechaInformeConformidad DateTime? @map("fecha_informe_conformidad")
  numeroFactura           String?   @map("numero_factura")
  observacion             String?

  proveedorId              Int?                  @map("proveedor_id")
  proveedor                Proveedor?            @relation(fields: [proveedorId], references: [id])
  fuenteFinanciamientoId   Int?                  @map("fuente_financiamiento_id")
  fuenteFinanciamiento     FuenteFinanciamiento? @relation(fields: [fuenteFinanciamientoId], references: [id])
  responsableConformidadId Int?                  @map("responsable_conformidad_id")
  responsableConformidad   Usuario?              @relation("IngresoResponsableConformidad", fields: [responsableConformidadId], references: [id])
  unidadSolicitanteId      Int?                  @map("unidad_solicitante_id")
  unidadSolicitante        Unidad?               @relation(fields: [unidadSolicitanteId], references: [id])

  // Auditoria: quien registro (automatico).
  registradoPorId Int     @map("registrado_por_id")
  registradoPor   Usuario @relation("IngresoRegistradoPor", fields: [registradoPorId], references: [id])

  // Anulacion (null salvo cuando se anula).
  anuladoPorId    Int?      @map("anulado_por_id")
  anuladoPor      Usuario?  @relation("IngresoAnuladoPor", fields: [anuladoPorId], references: [id])
  anuladoEn       DateTime? @map("anulado_en")
  motivoAnulacion String?   @map("motivo_anulacion")

  detalles    IngresoDetalle[]
  movimientos MovimientoKardex[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Unico por almacen + gestion + numero. Los NULL (borradores) conviven.
  @@unique([almacenId, gestion, numero])
  @@index([almacenId])
  @@index([estado])
  @@index([fuenteFinanciamientoId])
  @@map("ingresos")
}

/// Linea de un Ingreso = un LOTE de stock. Conserva su cantidad, su precio y su
/// SALDO. El almacen y la fuente del lote los aporta el Ingreso. El stock de un
/// item no es un numero: es la suma de los saldos de sus lotes. `saldoCantidad`
/// se modifica SIEMPRE dentro de la transaccion que lo mueve (aprendizaje del
/// sistema viejo, que lo actualizaba fuera de transaccion y se desincronizaba).
model IngresoDetalle {
  id        Int     @id @default(autoincrement())
  ingresoId Int     @map("ingreso_id")
  ingreso   Ingreso @relation(fields: [ingresoId], references: [id])
  itemId    Int     @map("item_id")
  item      Item    @relation(fields: [itemId], references: [id])

  cantidad       Decimal @db.Decimal(12, 2)
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(12, 5)
  saldoCantidad  Decimal @map("saldo_cantidad") @db.Decimal(12, 2)

  movimientos MovimientoKardex[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ingresoId])
  @@index([itemId])
  @@map("ingreso_detalles")
}

/// Libro de movimientos (Kardex) por item + almacen. Nunca se borra: es la
/// fuente para recalcular saldos si hiciera falta. Por ahora ENTRADA (ingreso
/// confirmado) y REVERSION (anulacion). SALIDA llega con Egresos.
model MovimientoKardex {
  id        Int            @id @default(autoincrement())
  tipo      TipoMovimiento
  itemId    Int            @map("item_id")
  item      Item           @relation(fields: [itemId], references: [id])
  almacenId Int            @map("almacen_id")
  almacen   Almacen        @relation(fields: [almacenId], references: [id])

  cantidad       Decimal @db.Decimal(12, 2)
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(12, 5)

  // Origen del movimiento (el ingreso y el lote que lo generaron).
  ingresoId        Int?            @map("ingreso_id")
  ingreso          Ingreso?        @relation(fields: [ingresoId], references: [id])
  ingresoDetalleId Int?            @map("ingreso_detalle_id")
  ingresoDetalle   IngresoDetalle? @relation(fields: [ingresoDetalleId], references: [id])

  /// Fecha del movimiento (la del documento; para el ingreso, su fechaRemision).
  fecha  DateTime
  motivo String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([itemId, almacenId])
  @@index([ingresoId])
  @@index([ingresoDetalleId])
  @@map("movimientos_kardex")
}
