// Sistema de Almacenes (multi-almacen) — Institucion Publica
// Paso 2 del roadmap: catalogo y usuarios. NO incluye aun stock/ingresos/egresos/kardex.
// Docs: ver CLAUDE.md en la raiz del repo.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Rol {
  super_admin
  admin
  solicitador
  aprobador
  responsable_almacen
  observador_almacen
}

// ---------------------------------------------------------------------------
// Entidades
// ---------------------------------------------------------------------------

/// Area administrativa (ej. Unidad de Planificacion).
/// Jerarquica: cada unidad puede tener un padre (sin limite de niveles).
/// Si padreId es null, es una Oficina Inicial (raiz).
model Unidad {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  sigla  String  @unique
  activo Boolean @default(true)

  // Jerarquia auto-referenciada (similar a Partida pero sin limite de niveles).
  padreId Int?     @map("padre_id")
  padre   Unidad?  @relation("UnidadJerarquia", fields: [padreId], references: [id])
  hijos   Unidad[] @relation("UnidadJerarquia")

  usuarios Usuario[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([padreId])
  @@map("unidades")
}

/// Almacen fisico. La institucion tiene 9+.
model Almacen {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  activo Boolean @default(true)

  usuarios     Usuario[]
  observadores UsuarioAlmacenObservado[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("almacenes")
}

/// Usuario del sistema. Se crea solo desde el modulo usuarios (no hay registro publico).
/// unidadId y almacenId son independientes entre si y opcionales segun el rol:
///   - super_admin / admin: sin unidad ni almacen, y sin cargo obligatorio.
///   - solicitador: unidad + almacen requeridos.
///   - aprobador: unidad + almacen requeridos (unico activo por unidad).
///   - responsable_almacen: unidad + almacen requeridos (unico activo por almacen).
///   - observador_almacen: sin almacen fijo (usa UsuarioAlmacenObservado).
/// `cargo` es opcional en la BD porque los dos roles administrativos no lo
/// llevan; para el resto lo exige el service.
/// `nombre` y `cargo` se guardan SIEMPRE en MAYUSCULAS (normalizado en el service).
model Usuario {
  id       Int     @id @default(autoincrement())
  nombre   String
  cargo    String?
  usuario  String  @unique
  password String
  rol      Rol
  activo   Boolean @default(true)

  unidadId  Int?     @map("unidad_id")
  unidad    Unidad?  @relation(fields: [unidadId], references: [id])
  almacenId Int?     @map("almacen_id")
  almacen   Almacen? @relation(fields: [almacenId], references: [id])

  almacenesObservados UsuarioAlmacenObservado[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([unidadId])
  @@index([almacenId])
  @@map("usuarios")
}

/// Tabla intermedia (muchos-a-muchos) para los almacenes que un observador_almacen puede ver.
model UsuarioAlmacenObservado {
  id        Int @id @default(autoincrement())
  usuarioId Int @map("usuario_id")
  almacenId Int @map("almacen_id")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  almacen Almacen @relation(fields: [almacenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([usuarioId, almacenId])
  @@index([almacenId])
  @@map("usuario_almacen_observado")
}

/// Clasificador por Objeto del Gasto (jerarquico, hasta 5 niveles).
/// NO se crea a mano: se importa/semilla desde el documento oficial (ver prisma/seed.ts).
/// nivel = 5 - (cantidad de ceros finales del codigo de 5 digitos).
/// seleccionable = true SOLO en nodos hoja (los unicos asignables a un Item).
model Partida {
  id                Int     @id @default(autoincrement())
  codigo            String  @unique
  denominacion      String
  nivel             Int
  seleccionable     Boolean @default(false)
  activo            Boolean @default(true)
  ultimoCorrelativo Int     @default(0) @map("ultimo_correlativo")

  padreId Int?      @map("padre_id")
  padre   Partida?  @relation("PartidaJerarquia", fields: [padreId], references: [id])
  hijos   Partida[] @relation("PartidaJerarquia")

  items Item[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([padreId])
  @@map("partidas")
}

/// Proveedor de la institucion. Sera referenciado por Ingreso (fase posterior),
/// por eso nunca se borra: baja logica via `activo`.
/// nit es opcional (hay proveedores sin NIT) pero unico cuando existe:
/// Postgres admite multiples NULL en un indice unico.
model Proveedor {
  id        Int     @id @default(autoincrement())
  nombre    String
  nit       String? @unique
  telefono  String?
  /// Nombre de la persona de contacto (ej. "Juan Perez, ejecutivo de ventas").
  contacto  String?
  direccion String?
  activo    Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("proveedores")
}

/// Fuente de financiamiento del Ingreso (Recursos Especificos, Banco Mundial,
/// COSUDE, DANIDA, programas TGN...). Va en la CABECERA del Ingreso: una sola
/// fuente por ingreso. El stock se separa por fuente porque cada financiador
/// exige rendir cuentas de SU plata (ver docs/decisiones-ingresos.md, punto 1).
/// Baja logica siempre: quedara referenciada por lotes historicos y borrarla
/// romperia el kardex, igual que pasa con Proveedor.
model FuenteFinanciamiento {
  id     Int     @id @default(autoincrement())
  nombre String  @unique
  /// Opcional, por si el area financiera maneja un codigo propio.
  codigo String?
  activo Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fuentes_financiamiento")
}

/// Item real de almacen (catalogo compartido entre todos los almacenes).
/// codigo autogenerado al crear: {partida.codigo}-{correlativo padStart(6)} (ej. "39700-000001").
/// El stock NO vive aqui (ira en StockAlmacen, fase posterior).
model Item {
  id           Int     @id @default(autoincrement())
  codigo       String  @unique
  descripcion  String
  unidadMedida String  @map("unidad_medida")
  // Ruta publica relativa de la imagen referencial (ej. "/uploads/items/12-a3f9.webp").
  // Null = sin imagen. El binario vive en el filesystem, no en la DB.
  imagenUrl    String? @map("imagen_url")
  activo       Boolean @default(true)

  partidaId Int     @map("partida_id")
  partida   Partida @relation(fields: [partidaId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([partidaId])
  @@map("items")
}
